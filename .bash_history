echo "===== TOP MEMORY =====" && ./otProcessManager topProcess 5 memory && echo "===== TOP CPU =====" && ./otProcessManager topProcess 5 cpu && echo "===== START PROCESS =====" && sleep 1000 & sleep_pid=$! && echo "Started sleep with PID $sleep_pid" && echo "===== KILL BY PID =====" && ./otProcessManager killProcess $sleep_pid && echo "===== START AGAIN =====" && sleep 1000 & && \
echo "===== KILL BY NAME =====" && ./otProcessManager killProcess sleep && echo "===== ORPHAN PROCESS =====" && ./otProcessManager listOrphanProcess && echo "===== ZOMBIE PROCESS =====" && ./otProcessManager listZoombieProcess && echo "===== WAITING PROCESS =====" && ./otProcessManager ListWaitingProcess && echo "===== RUNNING DURATION =====" && ./otProcessManager RunningDurationProcess bash && echo "===== KILL LEAST PRIORITY =====" && ./otProcessManager killLeastPriorityProcess
echo "===== PART A START ====="
