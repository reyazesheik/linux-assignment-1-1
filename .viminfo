""1	LINE	0
	start
	    alias=$4
	
	    path=$(grep "^$alias:" services.txt | cut -d ':' -f2)
	
	    if [ -z "$path" ]; then
	        echo "Service not found"
	        exit 1
	    fi
	
	    echo "Starting service..."
	
	    nohup bash $path > $alias.log 2>&1 &
	    
	    pid=$!
	    echo $pid > $alias.pid
	
	    echo "Service started with PID $pid"
	    ;
|3,1,1,1,19,0,1777386472,"start","    alias=$4","","    path=$(grep \"^$alias:\" services.txt | cut -d ':' -f2)","","    if [ -z \"$path\" ]; then","        echo \"Service not found\"","        exit 1","    fi","","    echo \"Starting service...\"","","    nohup bash $path > $alias.log 2>&1 &","    ","    pid=$!","    echo $pid > $alias.pid","","    echo \"Service started with PID $pid\"","    ;"
